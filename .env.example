# ======================================================
# arXivClaw configuration template (copy this file to .env)
# Usage: cp .env.example .env
# Notes:
# 1) This file is a template. Do not put real secrets here.
# 2) Put real secrets only in .env (already ignored by .gitignore).
# ======================================================

# === ArXiv fetch settings ===
# [Optional] arXiv query string (official arXiv query syntax)
ARXIV_QUERY=cat:cs.AI OR cat:cs.CV

# [Optional] Max papers fetched per run (5-20 for debugging, 500-3000 for production)
ARXIV_MAX_RESULTS=500

# [Optional] HTTP timeout (seconds) for each arXiv request
ARXIV_TIMEOUT_SECONDS=30

# [Optional] Max retry attempts when arXiv request fails due to timeout/network/5xx/429
ARXIV_MAX_RETRIES=3

# [Optional] Base backoff time (seconds), retries use exponential backoff (base * 2^attempt)
ARXIV_RETRY_BACKOFF_SECONDS=2.0


# === LLM settings (Gemini example) ===
# [Required] OpenAI-compatible base URL (recommended for Gemini)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# [Required] Your LLM API key
LLM_API_KEY=REPLACE_WITH_YOUR_LLM_API_KEY

# [Optional] Model name
LLM_MODEL=gemini-3.1-flash-lite-preview

# [Optional] LLM request timeout in seconds
LLM_TIMEOUT_SECONDS=60

# [Optional] Sleep interval (seconds) between scoring requests to reduce rate limits
LLM_REQUEST_INTERVAL_SECONDS=5.0


# === Relevance matching settings ===
# [Required] Your interest keywords, separated by commas
KEYWORDS=agent, video generation, world model, LLM, VLM

# [Optional] Minimum score threshold (0-100)
# Primary threshold for paper selection
MIN_RELEVANCE_SCORE=50

# [Optional] Minimum number of papers to send per run
# Logic:
# 1) If papers above MIN_RELEVANCE_SCORE are greater than this value, send all above-threshold papers (no upper limit).
# 2) Otherwise, send top-N papers by score, where N = MIN_DAILY_PUSH_COUNT.
MIN_DAILY_PUSH_COUNT=50


# === Email SMTP settings (Brevo example) ===
# [Usually fixed]
SMTP_HOST=smtp-relay.brevo.com

# [Usually fixed]
SMTP_PORT=587

# [Required] Brevo SMTP login (visible in SMTP & API page)
SMTP_USER=REPLACE_WITH_BREVO_SMTP_LOGIN

# [Required] Brevo SMTP key
SMTP_PASSWORD=REPLACE_WITH_BREVO_SMTP_KEY

# [Required] Sender email (must be valid/verified in Brevo)
EMAIL_FROM=sender@example.com

# [Required] Recipient email (where digest emails are delivered)
EMAIL_TO=receiver@example.com


# === Runtime settings ===
# [Usually unchanged] State DB path (used for dedup in normal mode)
STATE_DB_PATH=data/state.db

# [Optional] Log level: INFO / WARNING / ERROR
LOG_LEVEL=INFO

# [Optional] Scheduler timezone
TIMEZONE=America/Los_Angeles

# [Optional] Daily run time (24-hour format)
RUN_HOUR=14
RUN_MINUTE=0

# [Important] true = run once only (debug mode)
# Debug mode automatically:
# 1) enables verbose logs
# 2) ignores state.db (no dedup and no persistence)
# Set to false for production scheduled mode
RUN_ONCE=true

# [Optional] Send a startup/init email when the app process starts
# This email confirms arXivClaw is running and summarizes key config meanings.
INIT_EMAIL_ON_STARTUP=true
